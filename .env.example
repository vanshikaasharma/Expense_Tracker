# Supabase PostgreSQL connection string
# Supabase → Project Settings → Database → Connection string → URI
# Use "Transaction pooler" (port 6543) for the Express API.

DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Optional: server port (default 3000)
# PORT=3000

# Optional: disable SSL for local Postgres only
# PGSSLMODE=disable
# DATABASE_URL=postgresql://postgres:password@localhost:5432/expense_tracker
